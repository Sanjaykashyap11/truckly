# ─── Gemini API ───────────────────────────────────────────────────────────────
# Option A: Direct Gemini API key (easier for local dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Vertex AI (recommended for GCP deployment)
USE_VERTEX_AI=false
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ─── Model ────────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash-preview-native-audio-dialog

# ─── Samsara ELD API ──────────────────────────────────────────────────────────
# Real fleet data from JY Carriers (49 live drivers)
# Falls back to mock data if not set
SAMSARA_API_KEY=your_samsara_api_key_here

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Update these after Cloud Run deployment
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
